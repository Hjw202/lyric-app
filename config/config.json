{
  "bluetooth": {
    "adapter": "/org/bluez/hci0",
    "device_name": "LyricSpeaker"
  },
  "display": {
    "default_style": {
      "font_size": 48,
      "color": [0, 255, 0],
      "bg_color": [0, 0, 0],
      "line_spacing": 10,
      "padding": 40,
      "char_interval": 200
    }
  },
  "audio": {
    "presets": {
      "rock": {
        "module": "module-ladspa-sink",
        "label": "rock"
      },
      "pop": {
        "module": "module-ladspa-sink",
        "label": "pop"
      },
      "classical": {
        "module": "module-ladspa-sink",
        "label": "classical"
      },
      "flat": {
        "module": null,
        "label": null
      }
    },
    "default_volume": 70
  },
  "lyrics": {
    "api_base": "https://music.163.com",
    "cache_dir": "/var/cache/lyric-app/lyrics",
    "cache_ttl": 2592000,
    "request_timeout": 10
  },
  "web": {
    "host": "127.0.0.1",
    "port": 8080,
    "kiosk": {
      "enabled": true,
      "browser": "chromium-browser",
      "flags": ["--kiosk", "--noerrdialogs", "--disable-infobars", "--disable-gpu", "--no-sandbox"]
    }
  },
  "logging": {
    "web_file": "/var/log/lyric-app/lyric-web.log",
    "level": "INFO"
  }
}
